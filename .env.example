# MaterialSearch example config

# Scan roots (comma separated absolute paths)
ASSETS_PATH=C:\Users\Administrator\Pictures,C:\Users\Administrator\Videos

# Skip roots (comma separated absolute paths)
SKIP_PATH=C:\Users\Administrator\AppData

# Ignore keywords in path/file name
IGNORE_STRINGS=thumb,avatar,__MACOSX,icons,cache

# File extensions
IMAGE_EXTENSIONS=.jpg,.jpeg,.png,.gif,.heic,.webp,.bmp
VIDEO_EXTENSIONS=.mp4,.flv,.mov,.mkv,.webm,.avi

# Scan tuning
SCAN_PROCESS_BATCH_SIZE=4
IMAGE_MIN_WIDTH=64
IMAGE_MIN_HEIGHT=64
AUTO_SCAN=False
AUTO_SCAN_START_TIME=22:30
AUTO_SCAN_END_TIME=8:00
AUTO_SAVE_INTERVAL=100
ENABLE_CHECKSUM=False

# Model / device
MODEL_NAME=OFA-Sys/chinese-clip-vit-base-patch16
DEVICE=auto

# Search defaults
CACHE_SIZE=64
POSITIVE_THRESHOLD=36
NEGATIVE_THRESHOLD=36
IMAGE_THRESHOLD=85

# Server
HOST=127.0.0.1
PORT=8085
FLASK_DEBUG=False

# Login
ENABLE_LOGIN=False
USERNAME=admin
PASSWORD=MaterialSearch

# Paths
SQLALCHEMY_DATABASE_URL=sqlite:///./instance/assets.db
TEMP_PATH=./tmp
VIDEO_EXTENSION_LENGTH=0
